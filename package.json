{
  "name": "surface-test",
  "version": "1.0.0",
  "description": "",
  "private": true,
  "main": "index.js",
  "scripts": {
    "install:all": "npm install && cd backend && npm install && cd ../frontend && npm install",
    "dev": "concurrently --kill-others-on-fail --names \"BACK,FRONT\" --prefix-colors \"blue,green\" \"npm run dev:back\" \"npm run dev:front\"",
    "dev:back": "cd backend && npm run dev",
    "dev:front": "cd frontend && npm run dev",
    "build": "cd frontend && npm run build",
    "lint": "cd frontend && npm run lint"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "vite": "^8.0.10"
  },
