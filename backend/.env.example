DATABASE_URL="postgresql://user:pass@host/dbname?sslmode=require"
PORT=5001
JWT_SECRET="your_jwt_secret"

# MercadoPago (obter em: https://www.mercadopago.com.br/developers/panel)
MERCADO_PAGO_ACCESS_TOKEN=""
MERCADO_PAGO_WEBHOOK_SECRET=""

# ─── Email ───────────────────────────────────────────
# EMAIL_PROVIDER: "smtp" | "sendgrid" | vazio = modo preview (log only)
EMAIL_PROVIDER=
EMAIL_FROM=noreply@surface.com.br
EMAIL_FROM_NAME=Surface

# SendGrid (se EMAIL_PROVIDER=sendgrid)
SENDGRID_API_KEY=

# SMTP genérico (se EMAIL_PROVIDER=smtp — Mailtrap, Gmail, SES, etc.)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
