DATABASE_URL="postgresql://user:pass@host/dbname?sslmode=require"
PORT=5001
JWT_SECRET="your_jwt_secret"

# ─── Frontend ────────────────────────────────────────
# URL publica do frontend (obrigatorio em producao)
FRONTEND_URL=http://localhost:5173

# ─── Email ───────────────────────────────────────────
# EMAIL_PROVIDER: "smtp" | "sendgrid" | vazio = modo preview (log only)
# Em producao, defina obrigatoriamente como "smtp" ou "sendgrid"
EMAIL_PROVIDER=
EMAIL_FROM=noreply@surface.com.br
EMAIL_FROM_NAME=Surface

# SendGrid (se EMAIL_PROVIDER=sendgrid)
SENDGRID_API_KEY=

# SMTP genérico (se EMAIL_PROVIDER=smtp — Mailtrap, Gmail, SES, etc.)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
